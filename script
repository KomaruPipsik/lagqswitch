-- LocalScript: Ultimate Lag Switch by Pixie
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Настройки
local bindKey = Enum.KeyCode.V
local isBinding = false
local lagDuration = 0.7 -- Как просил

-- СОЗДАНИЕ GUI
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
ScreenGui.Name = "LagSwitchUI"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 280, 0, 160)
MainFrame.Position = UDim2.new(0.5, -140, 0.5, -80)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Visible = false
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(45, 45, 45)

local Title = Instance.new("TextLabel", MainFrame)
Title.Text = "LAG SWITCH | by: Pixie" -- Как просил
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.fromRGB(200, 200, 200)
Title.Font = Enum.Font.GothamBold

local BindBtn = Instance.new("TextButton", MainFrame)
BindBtn.Text = "KEY: V"
BindBtn.Size = UDim2.new(0.8, 0, 0, 45)
BindBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
BindBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
BindBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)

-- ЛОГИКА
local isLagging = false

local function performLag()
    if isLagging then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local direction = hrp.CFrame.LookVector
    local speed = hrp.AssemblyLinearVelocity.Magnitude
    if speed < 1 then speed = 20 end
    
    isLagging = true
    
    -- 1. Создаем анти-гравитационное поле (VectorForce)
    local attachment = Instance.new("Attachment", hrp)
    local vf = Instance.new("VectorForce", hrp)
    vf.Attachment0 = attachment
    vf.Force = Vector3.new(0, workspace.Gravity * hrp:GetMass(), 0) -- Компенсируем гравитацию
    
    -- Заморозка
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.Anchored = true
    
    task.wait(lagDuration) -- 0.7 сек
    
    -- 2. Телепорт
    local targetPos = hrp.Position + (direction * 10) + Vector3.new(0, 20, 0)
    hrp.CFrame = CFrame.new(targetPos, targetPos + direction)
    
    hrp.Anchored = false
    
    -- 3. Импульс полета
    local boost = math.clamp(speed / 50, 1.0, 3.0)
    hrp.AssemblyLinearVelocity = (direction * (100 * boost)) + Vector3.new(0, 60, 0)
    
    -- 4. Отключаем анти-гравитацию через 2 секунды
    task.wait(2) 
    vf:Destroy()
    attachment:Destroy()
    
    isLagging = false
end

-- ВВОД (Только клавиатура, без мыши)
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        -- Принимаем только KeyCode (клавиатура)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
            bindKey = input.KeyCode
            BindBtn.Text = "KEY: " .. bindKey.Name
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        MainFrame.Visible = not MainFrame.Visible
    end

    if not gpe and input.KeyCode == bindKey then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS KEY..."
end)
