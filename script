-- LocalScript: Ultimate Lag Switch by Pixie (Teleport Edition)
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- Настройки
local bindKey = Enum.KeyCode.V
local isBinding = false
local lagDuration = 1.0 -- Сделано ровно на 1 сек

-- СОЗДАНИЕ GUI
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
ScreenGui.Name = "LagSwitchUI"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 280, 0, 160)
MainFrame.Position = UDim2.new(0.5, -140, 0.5, -80)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.BorderSizePixel = 0
MainFrame.Visible = false
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(45, 45, 45)

local Title = Instance.new("TextLabel", MainFrame)
Title.Text = "LAG SWITCH | BY PIXIE"
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.fromRGB(200, 200, 200)
Title.Font = Enum.Font.GothamBold

local BindBtn = Instance.new("TextButton", MainFrame)
BindBtn.Text = "KEY: V"
BindBtn.Size = UDim2.new(0.8, 0, 0, 45)
BindBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
BindBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
BindBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)

-- Мобильная кнопка
local MobileBtn = Instance.new("TextButton", ScreenGui)
MobileBtn.Text = "MENU"
MobileBtn.Size = UDim2.new(0, 60, 0, 60)
MobileBtn.Position = UDim2.new(0, 20, 0.5, -30)
MobileBtn.Visible = UserInputService.TouchEnabled
MobileBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

local isLagging = false

-- ЛОГИКА ТЕЛЕПОРТАЦИИ
local function performLag()
    if isLagging then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local velocityBefore = hrp.AssemblyLinearVelocity
    local direction = velocityBefore.Unit
    
    -- Если игрок почти не двигался, телепортируем туда, куда он смотрит
    if velocityBefore.Magnitude < 1 or direction.Magnitude ~= direction.Magnitude then
        direction = hrp.CFrame.LookVector
    end
    
    isLagging = true
    
    -- "Замирание" (Останавливаем и фиксируем в воздухе)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    hrp.Anchored = true
    
    -- Ждем ровно 1 секунду
    task.wait(lagDuration)
    
    -- НАСТРОЙКА ДАЛЬНОСТИ ТЕЛЕПОРТА (Можешь менять эти цифры под себя)
    local distanceForward = 35 -- На сколько стадов телепортировать прямо
    local distanceUp = 25      -- На сколько стадов телепортировать вверх
    
    -- Высчитываем новую позицию для телепорта
    local teleportTargetPos = hrp.Position + (direction * distanceForward) + Vector3.new(0, distanceUp, 0)
    
    -- Мгновенно меняем координаты персонажа
    hrp.CFrame = CFrame.new(teleportTargetPos, teleportTargetPos + direction)
    
    -- Размораживаем персонажа
    hrp.Anchored = false
    
    -- Даем небольшую скорость вперед после телепорта, чтобы плавно приземлиться
    hrp.AssemblyLinearVelocity = (direction * 50) + Vector3.new(0, 20, 0)
    
    isLagging = false
end

-- ВВОД
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType:ToString():find("MouseButton") then
            bindKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            BindBtn.Text = "KEY: " .. (input.KeyCode.Name or input.UserInputType.Name)
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        MainFrame.Visible = not MainFrame.Visible
    end

    if not gpe and (input.KeyCode == bindKey or input.UserInputType == bindKey) then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS KEY..."
end)
