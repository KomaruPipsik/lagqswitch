-- АНИМАЦИЯ МЕНЮ
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local function toggleMenu()
    isMenuOpen = not isMenuOpen
    if isMenuOpen then
        MainFrame.Visible = true
        TweenService:Create(MainFrame, tweenInfo, {
            GroupTransparency = 0,
            Position = UDim2.new(0.5, -140, 0.5, -80)
        }):Play()
    else
        local hideTween = TweenService:Create(MainFrame, tweenInfo, {
            GroupTransparency = 1,
            Position = UDim2.new(0.5, -140, 0.45, -80)
        })
        hideTween:Play()
        hideTween.Completed:Wait()
        if not isMenuOpen then MainFrame.Visible = false end
    end
end

MobileBtn.MouseButton1Click:Connect(toggleMenu)

-- ЛОГИКА ТЕЛЕПОРТА
local isLagging = false

local function performLag()
    if isLagging then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local velocityBefore = hrp.AssemblyLinearVelocity
    local direction = velocityBefore.Unit
    
    if velocityBefore.Magnitude < 1 or direction.Magnitude ~= direction.Magnitude then
        direction = hrp.CFrame.LookVector
    end
    
    isLagging = true
    
    -- 1. ПОЛНАЯ ОСТАНОВКА И ЗАМОРОЗКА
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    hrp.Anchored = true
    
    -- 2. ЛАГ 1 СЕКУНДА
    task.wait(lagDuration)
    
    -- 3. ТЕЛЕПОРТ
    local randomOffset = Vector3.new(math.random(-5, 5), math.random(0, 8), math.random(-5, 5))
    local teleportTargetPos = hrp.Position + (direction * 35) + Vector3.new(0, 25, 0) + randomOffset
    
    hrp.CFrame = CFrame.new(teleportTargetPos, teleportTargetPos + direction)
    
    -- 4. РАЗБЛОКИРОВКА
    hrp.Anchored = false
    hrp.AssemblyLinearVelocity = (direction * 60) + Vector3.new(0, 30, 0)
    
    isLagging = false
end

-- ВВОД
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType:ToString():find("MouseButton") then
            bindKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            BindBtn.Text = "KEY: " .. (input.KeyCode.Name or input.UserInputType.Name)
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        toggleMenu()
    end

    if not gpe and (input.KeyCode == bindKey or input.UserInputType == bindKey) then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS KEY..."
end)
