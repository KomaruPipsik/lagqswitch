-- Состояние контроллера и конфигурация
local StateController = {
	isLagging = false,
	menuOpen = false,
	
	-- Физические параметры скачка
	freezeDuration = 1, -- Ровно 1 секунда для стабилизации
	cooldown = 3,
	upwardShift = 15, -- Смещение вверх для предотвращения коллизий
	forwardShift = 25, -- Смещение прямо
	jitterIntensity = 30, -- Интенсивность рандомизации вектора
	
	-- Бинды клавиш
	keybinds = {
		MenuToggle = Enum.KeyCode.LeftAlt, -- Открывает меню конфигурации
		VaultKey = Enum.KeyCode.Q,         -- Триггер самого скачка
		VaultMouse = Enum.UserInputType.MouseButton3
	}
}

