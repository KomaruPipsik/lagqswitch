-- ЛОГИКА ЛАГА
local function performLag()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- Убрана проверка на землю — работает и в воздухе
    -- Убрана проверка на движение — работает стоя

    local originalVel = hrp.AssemblyLinearVelocity

    -- Телепортируем вверх и вперёд перед заморозкой
    local lookDir = hrp.CFrame.LookVector
    hrp.CFrame = hrp.CFrame + Vector3.new(0, 8, 0) + lookDir * 5

    -- Замораживаем
    hrp.Anchored = true
    task.wait(lagDuration)
    hrp.Anchored = false

    -- Отталкивание вверх и вперёд
    local randomMultiplier = math.random(90, 140) / 100
    local pushForce = (lookDir * 40) + Vector3.new(0, 50, 0)
    hrp.AssemblyLinearVelocity = pushForce * randomMultiplier
end

-- ВВОД
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard
            or input.UserInputType == Enum.UserInputType.MouseButton2
            or input.UserInputType == Enum.UserInputType.MouseButton3 then
            bindKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            BindBtn.Text = "KEY: " .. (input.KeyCode.Name or input.UserInputType.Name)
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        MainFrame.Visible = not MainFrame.Visible
    end

    if not gpe and (input.KeyCode == bindKey or input.UserInputType == bindKey) then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS ANY KEY..."
end)
