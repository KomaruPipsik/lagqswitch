-- LocalScript: Ultimate Lag Switch by Pixie (Dynamic Velocity Edition)
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Настройки
local bindKey = Enum.KeyCode.V
local isBinding = false
local lagDuration = 0.4 -- Сокращено до 0.4 сек

-- СОЗДАНИЕ GUI
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
ScreenGui.Name = "LagSwitchUI"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 280, 0, 160)
MainFrame.Position = UDim2.new(0.5, -140, 0.5, -80)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Visible = false
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)
Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(45, 45, 45)

local Title = Instance.new("TextLabel", MainFrame)
Title.Text = "LAG SWITCH | BY PIXIE"
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.fromRGB(200, 200, 200)
Title.Font = Enum.Font.GothamBold

local BindBtn = Instance.new("TextButton", MainFrame)
BindBtn.Text = "KEY: V"
BindBtn.Size = UDim2.new(0.8, 0, 0, 45)
BindBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
BindBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
BindBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 6)

-- ЛОГИКА
local isLagging = false

local function performLag()
    if isLagging then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Запоминаем скорость ДО лага
    local velocityBefore = hrp.AssemblyLinearVelocity
    local speed = velocityBefore.Magnitude
    local direction = velocityBefore.Unit
    
    if speed < 1 or direction.Magnitude ~= direction.Magnitude then
        direction = hrp.CFrame.LookVector
        speed = 20 -- Базовая скорость
    end
    
    isLagging = true
    
    -- Заморозка
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    hrp.Anchored = true
    
    task.wait(lagDuration) -- 0.4 сек
    
    -- Телепорт
    local distanceForward = 10 
    local distanceUp = 20
    local targetPos = hrp.Position + (direction * distanceForward) + Vector3.new(0, distanceUp, 0)
    
    hrp.CFrame = CFrame.new(targetPos, targetPos + direction)
    
    hrp.Anchored = false
    
    -- ДИНАМИЧЕСКИЙ ПОДЛЕТ:
    -- Чем выше speed, тем сильнее множитель (от 1.0 до 3.0)
    local boostMultiplier = math.clamp(speed / 50, 1.0, 3.0)
    
    -- Импульс: кидает вперед и ВВЕРХ с учетом скорости
    -- 80 вперед и 50 вверх — база, умноженная на скорость
    local launchForce = (direction * (80 * boostMultiplier)) + Vector3.new(0, (50 * boostMultiplier), 0)
    
    hrp.AssemblyLinearVelocity = launchForce
    
    isLagging = false
end

-- ВВОД
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType:ToString():find("MouseButton") then
            bindKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            BindBtn.Text = "KEY: " .. (input.KeyCode.Name or input.UserInputType.Name)
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        MainFrame.Visible = not MainFrame.Visible
    end

    if not gpe and (input.KeyCode == bindKey or input.UserInputType == bindKey) then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS KEY..."
end)
