-- LocalScript: Ultimate Lag Switch v2
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local bindKey = Enum.KeyCode.V
local isBinding = false
local lagDuration = 1.5

-- GUI
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 280, 0, 160)
MainFrame.Position = UDim2.new(0.5, -140, 0.5, -80)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Visible = false
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

-- Заглушка для визуального "зависания" экрана
local FreezeFrame = Instance.new("Frame", ScreenGui)
FreezeFrame.Size = UDim2.new(1, 0, 1, 0)
FreezeFrame.BackgroundColor3 = Color3.new(0, 0, 0)
FreezeFrame.BackgroundTransparency = 1
FreezeFrame.Visible = true

local BindBtn = Instance.new("TextButton", MainFrame)
BindBtn.Text = "KEY: V"
BindBtn.Size = UDim2.new(0.8, 0, 0, 45)
BindBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
BindBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
BindBtn.TextColor3 = Color3.new(1, 1, 1)

local function performLag()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local originalVel = hrp.AssemblyLinearVelocity
    
    -- 1. Визуальный лаг (замораживаем экран)
    FreezeFrame.BackgroundTransparency = 0.5 
    
    -- 2. Замирание (физика)
    hrp.Anchored = true
    task.wait(lagDuration)
    hrp.Anchored = false
    
    -- 3. Убираем визуальный лаг
    FreezeFrame.BackgroundTransparency = 1
    
    -- 4. Отталкивание (теперь работает и в воздухе)
    -- Добавляем рандом, чтобы каждый раз было по-разному
    local randomFactor = Vector3.new(math.random(-10, 10), math.random(50, 90), math.random(-10, 10))
    local pushForce = (originalVel * 0.9) + randomFactor
    
    hrp.AssemblyLinearVelocity = pushForce
end

-- Обработка ввода
UserInputService.InputBegan:Connect(function(input, gpe)
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType:ToString():find("MouseButton") then
            bindKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            BindBtn.Text = "KEY: " .. (input.KeyCode.Name or input.UserInputType.Name)
            isBinding = false
        end
        return
    end

    if input.KeyCode == Enum.KeyCode.LeftAlt then
        MainFrame.Visible = not MainFrame.Visible
    end

    if not gpe and (input.KeyCode == bindKey or input.UserInputType == bindKey) then
        performLag()
    end
end)

BindBtn.MouseButton1Click:Connect(function()
    isBinding = true
    BindBtn.Text = "PRESS KEY..."
end)
