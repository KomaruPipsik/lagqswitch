-- Анимации TweenService
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function toggleMenu()
	StateController.menuOpen = not StateController.menuOpen
	
	if StateController.menuOpen then
		configMenu.Visible = true
		local tween = TweenService:Create(configMenu, tweenInfo, {GroupTransparency = 0})
		tween:Play()
	else
		local tween = TweenService:Create(configMenu, tweenInfo, {GroupTransparency = 1})
		tween:Play()
		tween.Completed:Connect(function()
			if not StateController.menuOpen then
				configMenu.Visible = false
			end
		end)
	end
end

-----------------------------------
-- ЛОГИКА ФИЗИКИ И СОСТОЯНИЯ
-----------------------------------

-- Фиксация позиции без Anchored
local function freezePhysics()
	local attachment = Instance.new("Attachment")
	attachment.Name = "VaultAttachment"
	attachment.Parent = rootPart

	local linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.Name = "VaultVelocity"
	linearVelocity.Attachment0 = attachment
	linearVelocity.MaxForce = math.huge
	linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
	linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
	linearVelocity.Parent = rootPart
	
	return linearVelocity, attachment
end

local function executeVault()
	-- Блокировка наложения команд
	if StateController.isLagging then return end
	StateController.isLagging = true
	
	-- Обновление UI
	statusText.Text = "OVERRIDING"
	statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
	
	-- 1. Заморозка вектора скорости
	local linVel, attachment = freezePhysics()
	
	-- 2. Задержка ровно на 1 секунду
	task.wait(StateController.freezeDuration)
	
	-- Очистка заморозки
	linVel:Destroy()
	attachment:Destroy()
	
	-- 3. Предиктивный скачок (вверх и прямо)
	local lookVector = rootPart.CFrame.LookVector
	local targetPosition = rootPart.CFrame.Position 
		+ Vector3.new(0, StateController.upwardShift, 0) 
		+ (lookVector * StateController.forwardShift)
	
	rootPart.CFrame = CFrame.new(targetPosition) * rootPart.CFrame.Rotation
	
	-- 4. Восстановление импульса с рандомизацией (Jitter)
	local randomX = math.random(-StateController.jitterIntensity, StateController.jitterIntensity)
	local randomY = math.random(10, StateController.jitterIntensity)
	local randomZ = math.random(-StateController.jitterIntensity, StateController.jitterIntensity)
	
	local jitterVector = Vector3.new(randomX, randomY, randomZ)
	local baseMomentum = lookVector * 40
	
	rootPart.AssemblyLinearVelocity = baseMomentum + jitterVector
	
	-- Кулдаун
	statusText.Text = "COOLDOWN"
	statusText.TextColor3 = Color3.fromRGB(100, 100, 100)
	
	task.wait(StateController.cooldown)
	
	-- Восстановление
	StateController.isLagging = false
	statusText.Text = "READY"
	statusText.TextColor3 = Color3.fromRGB(0, 255, 150)
end

-----------------------------------
-- ОБРАБОТКА ВВОДА
-----------------------------------
local function handleInput(input, gameProcessedEvent)
	-- Проверяем, сфокусирован ли игрок на чате. Игнорируем gameProcessedEvent для LeftAlt.
	if UserInputService:GetFocusedTextBox() then return end
	
	if input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode == StateController.keybinds.MenuToggle then
			toggleMenu()
		elseif input.KeyCode == StateController.keybinds.VaultKey then
			executeVault()
		end
	elseif input.UserInputType == StateController.keybinds.VaultMouse then
		if not gameProcessedEvent then
			executeVault()
		end
	end
end

UserInputService.InputBegan:Connect(handleInput)

-- Очистка интерфейса
humanoid.Died:Connect(function()
	screenGui:Destroy()
end)
